{
  "name": "aircare-ai",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:all": "npm install && npm install --prefix frontend && pip install -r backend/requirements.txt",
    "dev": "concurrently \"python backend/app.py\" \"npm run dev --prefix frontend\"",
    "start": "npm run dev"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
